{
    "name": "drainerlight/php-pdf-decompressor",
    "description": "Pure-PHP PDF decompressor: converts PDF 1.5+ cross-reference streams and object streams (ObjStm) into a classic PDF 1.4 structure, so parsers that only understand the traditional xref table (such as FPDI's free parser) can read them. A qpdf-free alternative — no external binaries.",
    "type": "library",
    "keywords": [
        "pdf",
        "php",
        "decompress",
        "decompressor",
        "uncompress",
        "object-stream",
        "objstm",
        "xref",
        "cross-reference-stream",
        "flatedecode",
        "pdf-parser",
        "fpdi",
        "qpdf"
    ],
    "homepage": "https://github.com/drainerlight/php-pdf-decompressor",
    "license": "MIT",
    "authors": [
        {
            "name": "drainerlight"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-zlib": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "setasign/fpdi-fpdf": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "PdfDecompressor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PdfDecompressor\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
